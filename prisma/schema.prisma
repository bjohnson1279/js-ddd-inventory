generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model InventoryModel {
  id         String @id
  sku        String
  locationId String @default("default")
  quantity   Int
  allocated  Int    @default(0)
  inTransit  Int    @default(0)
  version    Int    @default(1)

  @@unique([sku, locationId])
}

model BarcodeAssignmentModel {
  id           String   @id
  variantId    String
  barcodeValue String   @unique
  symbology    String
  source       String
  isPrimary    Boolean  @default(false)
  assignedAt   DateTime @default(now())
}

model ProductModel {
  id          String                @id
  name        String
  variants    ProductVariantModel[]
}

model ProductVariantModel {
  id                String       @id
  productId         String
  sku               String       @unique
  attributes        String       // Serialized variant attributes JSON string (e.g. [{"name":"size","value":"M"}])
  weightGrams       Int?
  volumeCubicMeters Float?
  product           ProductModel @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model SerializedItemModel {
  id           String                  @id
  serialNumber String
  sku          String
  status       String
  locationId   String
  tenantId     String
  registeredAt DateTime                @default(now())
  transitions  StatusTransitionModel[]

  @@unique([serialNumber, tenantId])
}

model StatusTransitionModel {
  id               String              @id
  serializedItemId String
  fromStatus       String
  toStatus         String
  reason           String?
  transitionedAt   DateTime
  actorId          String
  referenceId      String?
  serializedItem   SerializedItemModel @relation(fields: [serializedItemId], references: [id], onDelete: Cascade)
}

model KitModel {
  id         String               @id
  sku        String               @unique
  name       String
  components KitComponentModel[]
}

model KitComponentModel {
  id        String   @id
  kitId     String
  variantId String
  quantity  Int
  kit       KitModel @relation(fields: [kitId], references: [id], onDelete: Cascade)
}

model InventoryCostLayerModel {
  id                String   @id
  variantId         String
  locationId        String?
  tenantId          String
  originalQuantity  Int
  remainingQuantity Int
  unitCostCents     Int
  receivedAt        DateTime
  purchaseOrderId   String
  isConsumed        Boolean  @default(false)
  lotNumber         String?
  expirationDate    DateTime?
}

model JournalEntryModel {
  id               String             @id
  tenantId         String
  entryDate        DateTime
  description      String
  referenceId      String?
  accountingMethod String
  lines            JournalLineModel[]
}

model JournalLineModel {
  id              String            @id
  journalEntryId  String
  accountCode     String
  accountName     String
  accountCategory String
  debitOrCredit   String
  amountCents     Int
  memo            String?
  journalEntry    JournalEntryModel @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
}

model TenantConfigModel {
  tenantId         String @id
  accountingMethod String
  costingMethod    String
  currencyCode     String
  fiscalYearStart  String
}

model ProcessedWebhookModel {
  id          String   @id
  processedAt DateTime @default(now())
}

model OutboxEventModel {
  id            String    @id @default(uuid())
  eventName     String
  payload       String
  occurredOn    DateTime
  processedAt   DateTime?
  attempts      Int       @default(0)
  lastError     String?
  nextAttemptAt DateTime  @default(now())
}

model WebhookSubscriptionModel {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  targetUrl  String   @map("target_url")
  secret     String
  eventTypes String[] @map("event_types")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("webhook_subscriptions")
}

model WebhookDeliveryModel {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  subscriptionId String    @map("subscription_id")
  eventType      String    @map("event_type")
  payload        String    @db.Text
  status         String    @default("Pending")
  attempts       Int       @default(0)
  lastError      String?   @map("last_error") @db.Text
  nextAttemptAt  DateTime  @default(now()) @map("next_attempt_at")
  processedAt    DateTime? @map("processed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("webhook_deliveries")
}

model PurchaseOrderModel {
  id                  String                    @id
  purchaseOrderNumber String                    @unique
  vendorId            String
  tenantId            String
  status              String
  locationId          String
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  items               PurchaseOrderItemModel[]
}

model PurchaseOrderItemModel {
  id               String             @id
  purchaseOrderId  String
  variantId        String
  quantity         Int
  receivedQuantity Int                @default(0)
  unitCostCents    Int
  purchaseOrder    PurchaseOrderModel @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model ReorderPolicyModel {
  id              String   @id
  sku             String
  locationId      String
  reorderPoint    Int
  reorderQuantity Int
  safetyStock     Int
  dynamicRopEnabled Boolean  @default(false) @map("dynamic_rop_enabled")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sku, locationId])
}

model InventoryAuditModel {
  id          String                    @id
  auditNumber String                    @unique
  tenantId    String
  locationId  String
  status      String
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  items       InventoryAuditItemModel[]
}

model InventoryAuditItemModel {
  id               String              @id
  inventoryAuditId String
  variantId        String
  expectedQuantity Int
  countedQuantity  Int?
  isCounted        Boolean             @default(false)
  inventoryAudit   InventoryAuditModel @relation(fields: [inventoryAuditId], references: [id], onDelete: Cascade)
}

model RMAModel {
  id         String         @id
  rmaNumber  String         @unique
  tenantId   String
  customerId String
  locationId String
  status     String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  items      RMAItemModel[]
}

model RMAItemModel {
  id               String   @id
  rmaId            String
  variantId        String
  quantity         Int
  receivedQuantity Int      @default(0)
  unitCostCents    Int
  status           String
  disposition      String?
  rma              RMAModel @relation(fields: [rmaId], references: [id], onDelete: Cascade)
}

model QuarantineItemModel {
  id         String    @id
  variantId  String
  quantity   Int
  reason     String
  status     String
  locationId String
  tenantId   String
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
}

model DispatchRecordModel {
  id           String   @default(uuid())
  sku          String
  locationId   String
  quantity     Int
  dispatchedAt DateTime @default(now()) @map("dispatched_at")
  lotNumber    String?

  @@id([id, dispatchedAt])
  @@map("dispatch_records")
}

model DemandForecastModel {
  id                 String   @id @default(uuid())
  sku                String
  locationId         String
  forecastedQuantity Int
  periodStart        DateTime
  periodEnd          DateTime
  confidenceLevel    Float
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([sku, locationId, periodStart, periodEnd])
}

model ShipmentModel {
  id                 String   @id @default(uuid())
  sku                String
  quantity           Int
  destinationAddress String
  carrier            String
  trackingNumber     String?
  labelUrl           String?
  shippingRateCents  Int
  status             String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TenantModel {
  id        String      @id
  name      String
  createdAt DateTime    @default(now())
  users     UserModel[]
}

model UserModel {
  id           String          @id
  tenantId     String
  email        String
  passwordHash String
  name         String
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  tenant       TenantModel     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles    UserRoleModel[]
  apiTokens    ApiTokenModel[]

  @@unique([tenantId, email])
}

model RoleModel {
  id              String                @id
  name            String
  userRoles       UserRoleModel[]
  rolePermissions RolePermissionModel[]
}

model UserRoleModel {
  userId String
  roleId String
  user   UserModel @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   RoleModel @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermissionModel {
  roleId     String
  permission String
  role       RoleModel @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permission])
}

model ApiTokenModel {
  id        String    @id
  userId    String
  tenantId  String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      UserModel @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WarehouseLocationModel {
  id                   String   @id // e.g. "WH1-ZONEA-A03-R02-S01-B10"
  warehouseId          String
  zone                 String
  aisle                String
  rack                 String
  shelf                String
  bin                  String
  maxWeightGrams       Int
  maxVolumeCubicMeters Float
  gridX                Int      @default(0)
  gridY                Int      @default(0)
  width                Int      @default(1)
  height               Int      @default(1)
  createdAt            DateTime @default(now())

  @@unique([warehouseId, zone, aisle, rack, shelf, bin])
}

model NotificationModel {
  id        String   @id @default(uuid())
  tenantId  String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NetsuiteJournalMappingModel {
  id                 String   @id @default(uuid())
  journalEntryId     String   @unique
  netsuiteJournalId  String   @unique
  createdAt          DateTime @default(now())
}

model XeroJournalMappingModel {
  id                 String   @id @default(uuid())
  journalEntryId     String   @unique
  xeroJournalId      String   @unique
  createdAt          DateTime @default(now())
}

model QuickbooksJournalMappingModel {
  id                 String   @id @default(uuid())
  journalEntryId     String   @unique
  quickbooksJournalId String  @unique
  createdAt          DateTime @default(now())
}

model AuditDiscrepancyModel {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  type            String    
  referenceId     String    @map("reference_id") 
  externalRefId   String?   @map("external_ref_id")
  description     String
  status          String    @default("OPEN") 
  occurredAt      DateTime  @default(now()) @map("occurred_at")
  resolvedAt      DateTime? @map("resolved_at")
  resolutionNotes String?   @map("resolution_notes")

  @@map("audit_discrepancies")
}

model ComplianceLedgerModel {
  id             String   @id @default(uuid())
  sequenceNumber Int      @unique
  tenantId       String
  eventType      String
  payload        String   @db.Text
  timestamp      DateTime @default(now())
  previousHash   String
  hash           String
  signature      String
}

