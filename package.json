{
  "name": "js-ddd-inventory",
  "version": "1.0.0",
  "description": "Express.js API for a retail inventory system using DDD",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "nodemon src/index.ts",
